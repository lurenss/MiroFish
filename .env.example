# ==============================================================
# MiroFish Environment Configuration
# ==============================================================
# Supports any LLM API with OpenAI SDK format.
# Start with fewer than 40 simulation rounds to control costs.
# ==============================================================

# ===== OPTION A: CLIProxyAPI + Claude Max Subscription =====
# Use your Claude Pro/Max subscription via CLIProxyAPI proxy.
# Setup: brew install cliproxyapi && cliproxyapi --claude-login
# Then: brew services start cliproxyapi
# Docs: https://github.com/router-for-me/CLIProxyAPI
LLM_API_KEY=not-needed
LLM_BASE_URL=http://localhost:8317/v1
LLM_MODEL_NAME=claude-sonnet-4-6

# ===== OPTION B: Anthropic API (Pay-as-you-go) =====
# Get API key from https://console.anthropic.com
# LLM_API_KEY=sk-ant-api03-your-key-here
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_MODEL_NAME=claude-sonnet-4-6

# ===== OPTION C: OpenRouter (Multi-provider gateway) =====
# Get API key from https://openrouter.ai
# LLM_API_KEY=sk-or-v1-your-key-here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=anthropic/claude-sonnet-4-6

# ===== OPTION D: Alibaba Qwen (Original default) =====
# Get API key from https://bailian.console.aliyun.com/
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus

# ===== ZEP Memory Graph =====
# Required for knowledge graph and agent memory.
# Free monthly quota is sufficient for basic usage.
# Sign up at: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM (Optional) =====
# Use a faster/cheaper model for the simulation layer (Twitter/Reddit agents)
# while keeping the primary model for analysis, reports, and ontology.
# Only add these if you want dual-model mode.
# LLM_BOOST_API_KEY=not-needed
# LLM_BOOST_BASE_URL=http://localhost:8317/v1
# LLM_BOOST_MODEL_NAME=claude-haiku-4-5-20251001
